{{define "index"}}
<!doctype html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="{{.SiteDescription}}">
  <title>{{.SiteTitle}}</title>
  {{template "styles" .}}
  <style>
    .hero-card { padding-top: 8px; padding-bottom: 8px; }
    .latest-hero h2,
    .latest-kicker {
      margin: 0;
      font-weight: 700;
    }
    .latest-hero h2 {
      font-size: 1.35rem;
      line-height: 1.22;
    }
    .latest-hero { display: grid; gap: 0; margin-bottom: 0; padding-bottom: 0; }
    .latest-kicker {
      font-size: 0.82rem;
      line-height: 1;
      letter-spacing: 0;
      text-transform: none;
      color: var(--brand);
    }
    .kicker, .meta { letter-spacing: 0.03em; text-transform: uppercase; line-height: 1.2; }
    .kicker { margin: 0 0 8px; letter-spacing: 0.18em; font-size: 0.78rem; color: var(--brand); font-weight: 700; }
    .hero h1 { margin: 0; font-size: clamp(1.7rem, 3vw, 2.6rem); line-height: 1.22; font-weight: 700; }
    .hero p { margin: 8px 0 0; max-width: 58ch; color: var(--muted); }
    .site-description p { margin: 0; }
    .latest-kicker { font-size: 0.82rem; line-height: 1; letter-spacing: 0; text-transform: none; color: var(--brand); }
    .panel { margin: 0; display: grid; gap: 0; }
    .meta { font-size: 0.68rem; color: rgba(107, 107, 107, 0.68); }
    .sidebar { display: grid; gap: 16px; }
    .category-tree { display: block; }
    .category-group { margin: 0; padding: 0 0 2px; border-bottom: 1.5px solid var(--line); }
    .category-group:last-child { border-bottom: 0; }
    .category-group > summary {
      cursor: pointer;
      list-style: none;
      padding: 0 0 4px;
    }
    .category-group > summary::-webkit-details-marker { display: none; }
    .category-root,
    .category-branch a {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      padding: 10px 12px;
      background: rgba(255, 255, 255, 0.86);
    }
    .category-branch { display: grid; gap: 2px; margin-top: 2px; padding-left: 10px; }
    .category-label { display: flex; align-items: baseline; gap: 8px; flex-wrap: wrap; }
    .category-name {
      text-decoration: underline;
      text-decoration-color: var(--brand);
      text-decoration-thickness: 2px;
      text-underline-offset: 3px;
    }
    .category-count { color: var(--muted); font-size: 0.85rem; }
    .category-root-link { font-weight: 700; }
    .category-root-link:hover { background: rgba(217, 119, 6, 0.04); }
  </style>
</head>
<body>
  <div class="topbar">
    <div class="topbar-inner">
      <a class="brand" href="{{.HomeURL}}">
        <strong>{{.SiteTitle}}</strong>
        <span>{{.SiteSubtitle}}</span>
      </a>
      <nav class="tabs" aria-label="サイトナビゲーション">
        {{range .Tabs}}
        <a href="{{.TabURL}}"{{if .Active}} class="is-active"{{end}}>{{.TabLabel}}</a>
        {{end}}
      </nav>
    </div>
  </div>

  <main class="shell">
    <section class="hero">
      <div class="hero-card">
        <div class="site-description">{{.SiteDescriptionHTML}}</div>
      </div>
    </section>

    <div class="panel grid-2">
      <section class="section">
        <section class="hero latest-hero">
          <span class="kicker latest-kicker">Latest</span>
          <h2>最新記事</h2>
        </section>

        <div class="post-grid">
          {{if .LatestPosts}}
            {{range .LatestPosts}}
            <a class="post-card post-card-link" href="{{.URL}}" aria-label="{{.Title}}を開く">
              {{if .Category}}<p class="meta">{{.Category}}</p>{{else}}<p class="meta">ARTICLE</p>{{end}}
              <h3>{{.Title}}</h3>
              <p>{{.Summary}}</p>
              <p class="meta">{{dateOnly .PublishedAt}}</p>
            </a>
            {{end}}
          {{else}}
            <div class="post-card">
              <p class="meta">ARTICLE</p>
              <h3>記事がまだありません</h3>
              <p>公開済みの記事が追加されると、ここに表示されます。</p>
            </div>
          {{end}}
        </div>
      </section>

      <aside class="section sidebar" aria-label="カテゴリ一覧">
        <div class="category-tree">
          {{if .Categories}}
            {{range .Categories}}
              {{if .Children}}
              <details class="category-group"{{if .Open}} open{{end}}>
                <summary class="category-root">
                  <span class="category-label"><span class="category-name">{{.Name}}</span><span class="category-count">({{.Count}})</span></span>
                </summary>
                <div class="category-branch">
                  {{range .Children}}
                  <a href="{{.URL}}"><span class="category-label"><span class="category-name">{{.Name}}</span><span class="category-count">({{.Count}})</span></span></a>
                  {{end}}
                </div>
              </details>
              {{else}}
              <a class="category-root category-root-link" href="{{.URL}}">
                <span class="category-label"><span class="category-name">{{.Name}}</span><span class="category-count">({{.Count}})</span></span>
              </a>
              {{end}}
            {{end}}
          {{else}}
            <p class="note">カテゴリはまだありません。</p>
          {{end}}
        </div>
      </aside>
    </div>
  </main>

  <footer class="footer">
    <div class="shell">
      <span>{{.FootInformation}}</span>
      <span>{{.Copyright}}</span>
    </div>
  </footer>
</body>
</html>
{{end}}
