{{define "blog"}}
{{if .Breadcrumbs}}
<nav class="breadcrumb" aria-label="パンくずリスト">
  {{- range $i, $item := .Breadcrumbs -}}
    {{- if $i }}<span> / </span>{{ end -}}
    {{- if $item.URL -}}
      <a href="{{$item.URL}}">{{$item.Label}}</a>
    {{- else -}}
      <span>{{$item.Label}}</span>
    {{- end -}}
  {{- end -}}
</nav>
{{end}}
{{if .TitleImageURL}}<img class="title-image-hero" src="{{.TitleImageURL}}" alt="" loading="eager">{{end}}
<section class="blogs-intro">
    <span class="kicker list-kicker">{{.Meta}}</span>
    <h2>{{.Title}}</h2>
    {{if .PublishedAt}}<p class="meta">{{dateOnly .PublishedAt}}</p>{{end}}
</section>
<article class="section post-detail">
  <div class="content">{{.Content}}</div>
</article>
{{end}}
