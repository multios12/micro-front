{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "API Debug",
      "type": "go",
      "request": "launch",
      "mode": "debug",
      "program": "${workspaceFolder}/cmd/micro-front",
      "cwd": "${workspaceFolder}",
      "env": {
        "PORT": ":3001"
      }
    },
    {
      "name": "Open Front in Edge",
      "type": "pwa-msedge",
      "request": "launch",
      "url": "http://127.0.0.1:3000/",
      "webRoot": "${workspaceFolder}/front",
      "preLaunchTask": "front: dev",
      "sourceMaps": true,
      "sourceMapPathOverrides": {
        "vite://*": "${workspaceFolder}/front/*",
        "/@fs/*": "*",
        "src/*": "${workspaceFolder}/front/src/*",
        "/*": "${workspaceFolder}/front/*"
      }
    }
  ],
  "compounds": [
    {
      "name": "Dev: Front + API",
      "configurations": [
        "API Debug",
        "Open Front in Edge"
      ]
    }
  ]
}