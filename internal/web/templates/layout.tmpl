{{define "layout"}}
<!doctype html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="{{.SiteDescription}}">
  <title>{{.Title}} | {{.SiteTitle}}</title>
  <style>
    :root {
      color-scheme: light;
      --bg: #f7f4ef;
      --bg-elev: rgba(255, 255, 255, 0.82);
      --text: #1e1a17;
      --muted: #6b625a;
      --brand: #0f766e;
      --brand-weak: #d9f1ee;
      --line: rgba(31, 41, 55, 0.12);
      --shadow: 0 20px 60px rgba(15, 23, 42, 0.12);
      --radius-xl: 28px;
      --radius-lg: 20px;
      --radius-md: 16px;
      --max: 1120px;
    }
    * { box-sizing: border-box; }
    html, body { margin: 0; min-height: 100%; }
    body {
      font-family: "Noto Serif JP", "Hiragino Mincho ProN", "Yu Mincho", serif;
      background:
        radial-gradient(circle at top left, rgba(15, 118, 110, 0.18), transparent 35%),
        radial-gradient(circle at top right, rgba(234, 179, 8, 0.14), transparent 28%),
        linear-gradient(180deg, #fbfaf7 0%, #f1ece4 100%);
      color: var(--text);
      line-height: 1.8;
    }
    a { color: inherit; text-decoration: none; }
    .shell {
      width: min(var(--max), calc(100% - 32px));
      margin: 0 auto;
    }
    .topbar {
      position: sticky;
      top: 0;
      z-index: 10;
      backdrop-filter: blur(14px);
      background: rgba(251, 250, 247, 0.78);
      border-bottom: 1px solid var(--line);
    }
    .topbar-inner {
      width: min(var(--max), calc(100% - 32px));
      margin: 0 auto;
      display: flex;
      gap: 20px;
      align-items: center;
      justify-content: space-between;
      padding: 18px 0;
    }
    .brand {
      display: flex;
      flex-direction: column;
      gap: 4px;
    }
    .brand strong {
      font-size: 1.2rem;
      letter-spacing: 0.04em;
    }
    .brand span {
      font-size: 0.92rem;
      color: var(--muted);
    }
    .tabs {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      justify-content: flex-end;
    }
    .tabs a {
      padding: 10px 14px;
      border-radius: 999px;
      border: 1px solid transparent;
      background: rgba(255, 255, 255, 0.72);
      transition: transform 0.2s ease, border-color 0.2s ease, background 0.2s ease;
    }
    .tabs a:hover {
      transform: translateY(-1px);
      border-color: var(--line);
      background: #fff;
    }
    .tabs a.is-active {
      border-color: rgba(15, 118, 110, 0.26);
      color: var(--brand);
      font-weight: 700;
    }
    .hero {
      padding: 44px 0 18px;
    }
    .hero-card {
      background: var(--bg-elev);
      border: 1px solid rgba(255, 255, 255, 0.72);
      border-radius: var(--radius-xl);
      box-shadow: var(--shadow);
      padding: 34px;
      overflow: hidden;
      position: relative;
    }
    .hero-card::after {
      content: "";
      position: absolute;
      inset: auto -80px -120px auto;
      width: 260px;
      height: 260px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(15, 118, 110, 0.16), transparent 70%);
      pointer-events: none;
    }
    .kicker {
      margin: 0 0 10px;
      text-transform: uppercase;
      letter-spacing: 0.18em;
      font-size: 0.78rem;
      color: var(--brand);
      font-weight: 700;
    }
    .hero h1 {
      margin: 0;
      font-size: clamp(2rem, 5vw, 3.8rem);
      line-height: 1.15;
      letter-spacing: 0.02em;
    }
    .hero p {
      margin: 16px 0 0;
      max-width: 58ch;
      color: var(--muted);
    }
    .panel {
      margin: 28px 0 0;
      display: grid;
      gap: 20px;
    }
    .section {
      background: rgba(255, 255, 255, 0.76);
      border: 1px solid rgba(255, 255, 255, 0.84);
      border-radius: var(--radius-lg);
      box-shadow: 0 12px 40px rgba(15, 23, 42, 0.08);
      padding: 24px;
    }
    .section h2 {
      margin: 0 0 16px;
      font-size: 1.25rem;
    }
    .post-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: 18px;
    }
    .post-card {
      display: flex;
      flex-direction: column;
      gap: 12px;
      padding: 20px;
      border-radius: var(--radius-md);
      background: rgba(255, 255, 255, 0.92);
      border: 1px solid var(--line);
      min-height: 180px;
    }
    .post-card h3, .post-card h4 {
      margin: 0;
      font-size: 1.1rem;
      line-height: 1.35;
    }
    .post-card p, .meta, .note {
      margin: 0;
      color: var(--muted);
      font-size: 0.96rem;
    }
    .post-card .meta {
      font-size: 0.82rem;
      letter-spacing: 0.05em;
      text-transform: uppercase;
    }
    .post-detail {
      display: grid;
      gap: 18px;
    }
    .post-detail header {
      display: grid;
      gap: 8px;
    }
    .post-detail .content {
      white-space: pre-wrap;
      padding: 24px;
      width: 100%;
      max-width: none;
      border-radius: var(--radius-md);
      background: rgba(255, 255, 255, 0.9);
      border: 1px solid var(--line);
    }
    .grid-2 {
      display: grid;
      grid-template-columns: minmax(0, 1.6fr) minmax(280px, 0.9fr);
      gap: 20px;
    }
    .sidebar {
      display: grid;
      gap: 16px;
    }
    .category-tree {
      display: grid;
      gap: 12px;
    }
    .category-group {
      margin: 0;
      padding: 0;
    }
    .category-group > summary {
      cursor: pointer;
      list-style: none;
    }
    .category-group > summary::-webkit-details-marker {
      display: none;
    }
    .category-root,
    .category-branch a {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      padding: 10px 12px;
      border-radius: var(--radius-md);
      border: 1px solid var(--line);
      background: rgba(255, 255, 255, 0.86);
    }
    .category-branch {
      display: grid;
      gap: 8px;
      margin-top: 8px;
      padding-left: 12px;
    }
    .category-label {
      display: flex;
      align-items: baseline;
      gap: 8px;
      flex-wrap: wrap;
    }
    .category-count {
      color: var(--muted);
      font-size: 0.85rem;
    }
    .chip {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 8px 12px;
      border-radius: 999px;
      background: var(--brand-weak);
      color: var(--brand);
      font-size: 0.86rem;
      font-weight: 700;
    }
    .footer {
      padding: 28px 0 40px;
      color: var(--muted);
      font-size: 0.92rem;
    }
    .footer .shell {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      justify-content: space-between;
      border-top: 1px solid var(--line);
      padding-top: 18px;
    }
    @media (max-width: 860px) {
      .topbar-inner, .footer .shell {
        flex-direction: column;
        align-items: flex-start;
      }
      .grid-2 {
        grid-template-columns: 1fr;
      }
      .hero-card, .section {
        padding: 22px;
      }
    }

    /* Mock-style overrides for public pages */
    body {
      font-family: "Noto Sans JP", "Hiragino Sans", "Yu Gothic", sans-serif;
      background: #fafafa;
      color: #191919;
      line-height: 1.7;
    }
    .topbar {
      background: rgba(250, 250, 250, 0.96);
      border-bottom: 1.5px solid rgba(217, 119, 6, 0.30);
      backdrop-filter: none;
    }
    .topbar-inner {
      padding: 16px 0;
    }
    .brand {
      display: flex;
      flex-direction: column;
      gap: 4px;
      padding-left: 10px;
      border-left: 3px solid #d97706;
    }
    .brand strong {
      font-size: 1rem;
      line-height: 1.05;
      letter-spacing: 0.02em;
    }
    .brand span {
      font-size: 0.76rem;
      line-height: 1.2;
      letter-spacing: 0.02em;
    }
    .tabs a {
      padding: 6px 0;
      border-radius: 0;
      background: transparent;
      border-bottom: 1px solid transparent;
      transition: none;
    }
    .tabs a.is-active {
      color: #d97706;
      border-bottom-color: #d97706;
      font-weight: 700;
    }
    .shell {
      width: min(1120px, calc(100% - 32px));
    }
    .hero {
      padding: 34px 0 10px;
    }
    .hero-card,
    .section {
      background: transparent;
      border: 0;
      border-bottom: 1.5px solid rgba(217, 119, 6, 0.30);
      border-radius: 0;
      box-shadow: none;
      padding: 22px 0;
      overflow: visible;
      position: relative;
    }
    .hero-card::after {
      content: none;
    }
    .hero h1 {
      margin: 0;
      font-size: clamp(1.7rem, 3vw, 2.6rem);
      line-height: 1.22;
      font-weight: 700;
    }
    .hero p {
      margin: 8px 0 0;
      max-width: 58ch;
      color: #6b6b6b;
    }
    .panel {
      margin: 0;
      display: grid;
      gap: 0;
    }
    .grid-2 {
      display: grid;
      grid-template-columns: minmax(0, 1.6fr) minmax(280px, 0.9fr);
      gap: 28px;
    }
    .section {
      padding: 11px 0;
    }
    .section h2 {
      margin: 0 0 8px;
      font-size: 1.05rem;
      font-weight: 700;
    }
    .post-grid {
      display: grid;
      gap: 0;
    }
    .post-grid-list {
      grid-template-columns: 1fr;
    }
    .post-grid-2 {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 22px;
    }
    .post-card {
      position: relative;
      display: grid;
      gap: 2px;
      padding: 0 0 4px;
      min-height: 0;
      border-top: 1.5px solid rgba(217, 119, 6, 0.30);
      align-content: start;
      background: transparent;
      border-radius: 0;
    }
    .post-card:first-child {
      border-top: 0;
    }
    .post-card-link {
      display: grid;
      text-decoration: none;
      color: inherit;
      padding-top: 8px;
    }
    .post-card-link:hover {
      background: rgba(217, 119, 6, 0.04);
    }
    .post-card h3, .post-card h4 {
      margin: 0;
      font-size: 0.92rem;
      line-height: 1.4;
      font-weight: 700;
    }
    .post-card p, .meta, .note {
      margin: 0;
      color: #6b6b6b;
      font-size: 0.95rem;
    }
    .meta {
      font-size: 0.68rem;
      letter-spacing: 0.03em;
      text-transform: uppercase;
      color: rgba(107, 107, 107, 0.68);
      line-height: 1.2;
    }
    .breadcrumb {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      align-items: center;
      margin: 0 0 14px;
      color: #4a4a4a;
      font-size: 0.78rem;
      letter-spacing: 0.04em;
      font-weight: 600;
    }
    .breadcrumb a {
      color: #4a4a4a;
      text-decoration: underline;
      text-decoration-color: rgba(74, 74, 74, 0.45);
      text-decoration-thickness: 1px;
      text-underline-offset: 2px;
    }
    .breadcrumb span {
      color: #7c7c7c;
    }
    .breadcrumb-tight {
      margin-bottom: 0;
    }
    .blogs-intro {
      display: grid;
      gap: 8px;
      margin: 8px 0 10px;
      padding: 0;
    }
    .blogs-intro .list-kicker {
      margin: 0;
      font-size: 0.82rem;
      line-height: 1;
      letter-spacing: 0;
      text-transform: none;
      color: #d97706;
    }
    .blogs-intro h2 {
      margin: 0;
      font-size: 1.35rem;
      line-height: 1.22;
      font-weight: 700;
    }
    .blogs-hero {
      padding-top: 0;
      padding-bottom: 10px;
    }
    .blogs-hero .hero-card {
      padding: 0 0 12px;
      border-bottom: 0;
    }
    .blogs-hero .chip {
      display: inline;
      padding: 0;
      border-radius: 0;
      background: transparent;
      color: #d97706;
      font-size: 0.82rem;
      font-weight: 700;
      line-height: 1;
    }
    .blogs-hero h2 {
      margin: 0;
      font-size: 1.35rem;
      line-height: 1.22;
      font-weight: 700;
    }
    .blogs-hero p {
      margin-top: 8px;
    }
    .blogs-section {
      border-bottom: 0;
      padding-top: 0;
      padding-bottom: 0;
    }
    .post-detail {
      display: grid;
      gap: 0;
    }
    .post-detail-tight {
      padding-top: 2px;
    }
    .post-detail header {
      display: grid;
      gap: 8px;
      padding-bottom: 12px;
      border-bottom: 1.5px solid rgba(217, 119, 6, 0.30);
    }
    .post-detail .content {
      white-space: pre-wrap;
      padding-top: 18px;
      width: 100%;
      max-width: none;
    }
    .mock-figure {
      margin: 18px 0 0;
      padding: 0;
      max-width: none;
    }
    .mock-image {
      display: block;
      width: 100%;
      height: auto;
      border: 1.5px solid rgba(217, 119, 6, 0.30);
    }
    .pagination {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin: 16px 0 0;
      align-items: center;
    }
    .pagination-link {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 32px;
      height: 32px;
      padding: 0 10px;
      border: 1px solid rgba(217, 119, 6, 0.30);
      background: #fff;
      color: #191919;
      font-size: 0.82rem;
    }
    .pagination-link.is-active {
      background: #fff1df;
      font-weight: 700;
    }
    .category-tree {
      display: block;
    }
    .category-group {
      margin: 0;
      padding: 0 0 2px;
      border-bottom: 1.5px solid rgba(217, 119, 6, 0.30);
    }
    .category-group > summary {
      cursor: pointer;
      list-style: none;
      padding: 0 0 4px;
    }
    .category-group > summary::-webkit-details-marker {
      display: none;
    }
    .category-root,
    .category-branch a {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      padding: 10px 12px;
      border-radius: 0;
      border: 1px solid rgba(217, 119, 6, 0.30);
      background: rgba(255, 255, 255, 0.86);
    }
    .category-branch {
      display: grid;
      gap: 2px;
      margin-top: 2px;
      padding-left: 10px;
    }
    .category-label {
      display: flex;
      align-items: baseline;
      gap: 8px;
      flex-wrap: wrap;
    }
    .category-count {
      color: #6b6b6b;
      font-size: 0.85rem;
    }
    .chip {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 8px 12px;
      border-radius: 999px;
      background: #fff1df;
      color: #d97706;
      font-size: 0.86rem;
      font-weight: 700;
    }
    .footer {
      padding: 28px 0 40px;
      color: #6b6b6b;
      font-size: 0.92rem;
    }
    .footer .shell {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      justify-content: space-between;
      border-top: 1px solid rgba(217, 119, 6, 0.30);
      padding-top: 18px;
    }
    .sidebar {
      display: grid;
      gap: 16px;
    }
  </style>
</head>
<body>
  <div class="topbar">
    <div class="topbar-inner">
      <a class="brand" href="{{.HomeURL}}">
        <strong>{{.SiteTitle}}</strong>
        <span>{{.SiteSubtitle}}</span>
      </a>
      <nav class="tabs" aria-label="サイトナビゲーション">
        {{range .Tabs}}
        <a href="{{.TabURL}}"{{if .Active}} class="is-active"{{end}}>{{.TabLabel}}</a>
        {{end}}
      </nav>
    </div>
  </div>

  <main class="shell">
    {{.Body}}
  </main>

  <footer class="footer">
    <div class="shell">
      <span>{{.FootInformation}}</span>
      <span>{{.Copyright}}</span>
    </div>
  </footer>
</body>
</html>
{{end}}
