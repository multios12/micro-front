{{define "styles"}}
  <style>
    :root {
      color-scheme: light;
      --bg: #fafafa;
      --bg-elev: #ffffff;
      --text: #1e1a17;
      --muted: #6b625a;
      --brand: #d97706;
      --brand-weak: #fff1df;
      --line: rgba(41, 29, 15, 0.3);
      --max: 1120px;
    }
    * { box-sizing: border-box; }
    html, body { margin: 0; min-height: 100%; }
    body {
      font-family: "Noto Sans JP", "Hiragino Sans", "Yu Gothic", sans-serif;
      background: #fafafa;
      color: #191919;
      line-height: 1.7;
    }
    a { color: inherit; text-decoration: none; }
    .shell { width: min(var(--max), calc(100% - 32px)); margin: 0 auto; }
    .topbar {
      background: rgba(250, 250, 250, 0.96);
      border-bottom: 1.5px solid rgba(217, 119, 6, 0.30);
      backdrop-filter: none;
    }
    .topbar-inner {
      width: min(var(--max), calc(100% - 32px));
      margin: 0 auto;
      display: flex;
      gap: 20px;
      align-items: center;
      justify-content: space-between;
      padding: 16px 0;
    }
    .brand {
      display: flex;
      flex-direction: column;
      gap: 4px;
      padding-left: 10px;
      border-left: 3px solid var(--brand);
    }
    .brand strong {
      font-size: 1rem;
      line-height: 1.05;
      letter-spacing: 0.02em;
    }
    .brand span {
      font-size: 0.76rem;
      line-height: 1.2;
      letter-spacing: 0.02em;
    }
    .tabs { display: flex; flex-wrap: wrap; justify-content: flex-end; gap: 10px; }
    .tabs a {
      padding: 0;
      border-radius: 0;
      background: transparent;
      border-bottom: 2px solid transparent;
      transition: none;
    }
    .tabs a:hover { transform: translateY(-1px); border-color: var(--brand); background: #fff; }
    .tabs a.is-active { border-color: var(--brand);color: var(--brand); font-weight: 700; }
    .hero { padding: 0px 0 18px; }
    .hero h1 { margin: 0; font-size: clamp(2rem, 5vw, 3.8rem); line-height: 1.15; letter-spacing: 0.02em; }
    .hero p { margin: 16px 0 0; max-width: 58ch; color: var(--muted); }
    .kicker { margin: 0 0 8px; color: var(--brand); font-size: 0.78rem; font-weight: 700; letter-spacing: 0.18em; }
    .panel { display: grid; gap: 20px; margin: 28px 0 0; }
    .section h2 { margin: 0 0 16px; font-size: 1.25rem; }
    .post-grid {
      margin-top: 8px
      display: grid;
      grid-template-columns: 1fr;
      gap: 8px;
    }
    .post-card {
      position: relative;
      display: grid;
      gap: 8px;
      padding: 8px 0 8px;
      border-top: 1.5px solid rgba(217, 119, 6, 0.30);
      align-content: start;
      background: transparent;
    }

    .post-card:first-child { border-top: 0; }
    .post-card-link {
      display: grid;
      text-decoration: none;
      color: inherit;
      padding-top: 8px;
      padding-bottom: 8px;
    }
    .post-card-link:hover { background: rgba(217, 119, 6, 0.04); }
    .post-card h3 {
      margin: 0;
      font-size: 0.92rem;
      line-height: 1.4;
      font-weight: 700;
    }
    .post-card p, .meta, .note { margin: 0; color: var(--muted); font-size: 0.96rem; }
    .post-card .meta { font-size: 0.82rem; letter-spacing: 0.05em; text-transform: uppercase; }
    .title-image-thumb,
    .title-image-hero {
      display: block;
      width: 100%;
      aspect-ratio: 16 / 9;
      object-fit: cover;
      background: #f2efe9;
    }
    .title-image-thumb { margin-bottom: 2px; }
    .title-image-hero { margin-bottom: 18px; }
    .blog-list-card {
      grid-template-columns: minmax(0, 1fr) 128px;
      gap: 14px;
      align-items: center;
    }
    .blog-list-card-body {
      display: grid;
      gap: 8px;
      min-width: 0;
    }
    .blog-list-card-image {
      width: 128px;
      max-width: 30vw;
      margin-bottom: 0;
      border-radius: 4px;
      justify-self: end;
    }
    .post-detail { display: grid; gap: 0px; }
    .post-detail .content { 
      padding-top: 18px; 
      width: 100%; 
      max-width: none;
    }

    .grid-2 { display: grid; grid-template-columns: minmax(0, 1.6fr) minmax(280px, 0.9fr); gap: 28px; }
    .chip {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 8px 12px;
      border-radius: 999px;
      background: var(--brand-weak);
      color: var(--brand);
      font-size: 0.86rem;
      font-weight: 700;
    }
    .footer {
      padding: 28px 0 40px;
      color: var(--muted);
      font-size: 0.92rem;
    }
    .footer .shell { display: flex; flex-wrap: wrap; justify-content: space-between; gap: 12px; padding-top: 18px; border-top: 1px solid var(--line); }
    @media (max-width: 860px) {
      .topbar-inner, .footer .shell {
        flex-direction: column;
        align-items: flex-start;
      }
      .grid-2 { grid-template-columns: minmax(0, 1.6fr) minmax(280px, 0.9fr) }
      .section { padding: 22px; }
      .blog-list-card {
        grid-template-columns: minmax(0, 1fr) 96px;
        gap: 12px;
      }
      .blog-list-card-image {
        width: 96px;
      }
    }
  </style>
{{end}}
