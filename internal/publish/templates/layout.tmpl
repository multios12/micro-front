{{define "layout"}}
<!doctype html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="{{.SiteDescription}}">
  <title>{{.Title}} | {{.SiteTitle}}</title>
  {{template "styles" .}}
  <style>
    .section {
      background: transparent;
      border: 0;
      border-radius: 0;
      box-shadow: none;
      overflow: visible;
      position: relative;
    }
    .hero h1 {
      margin: 0;
      font-size: clamp(1.7rem, 3vw, 2.6rem);
      line-height: 1.22;
      font-weight: 700;
    }
    .hero p {
      margin: 8px 0 0;
      max-width: 58ch;
      color: #6b6b6b;
    }
    .panel {
      margin: 0;
      display: grid;
      gap: 0;
    }
    .post-grid {
      display: grid;
      gap: 0;
    }

    .meta {
      font-size: 0.68rem;
      letter-spacing: 0.03em;
      text-transform: uppercase;
      color: rgba(107, 107, 107, 0.68);
      line-height: 1.2;
    }
    .breadcrumb {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      align-items: center;
      margin: 8px 0 14px;
      color: #4a4a4a;
      font-size: 0.78rem;
      letter-spacing: 0.04em;
      font-weight: 600;
    }
    .breadcrumb a {
      color: #4a4a4a;
      text-decoration: underline;
      text-decoration-color: rgba(74, 74, 74, 0.45);
      text-decoration-thickness: 1px;
      text-underline-offset: 2px;
    }
    .breadcrumb span {
      color: #7c7c7c;
    }
    .blogs-intro {
      display: grid;
      gap: 8px;
      margin: 8px 0 10px;
      padding: 0;
    }
    .blogs-intro .list-kicker {
      margin: 0;
      font-size: 0.82rem;
      line-height: 1;
      letter-spacing: 0;
      text-transform: none;
      color: var(--brand);
    }
    .blogs-intro h2 {
      margin: 0;
      font-size: 1.35rem;
      line-height: 1.22;
      font-weight: 700;
    }
    .blogs-hero {
      padding-top: 0;
      padding-bottom: 10px;
    }
    .blogs-hero .hero-card {
      padding: 0 0 12px;
      border-bottom: 0;
    }
    .blogs-hero .chip {
      display: inline;
      padding: 0;
      border-radius: 0;
      background: transparent;
      color: var(--brand);
      font-size: 0.82rem;
      font-weight: 700;
      line-height: 1;
    }
    .blogs-hero h2 {
      margin: 0;
      font-size: 1.35rem;
      line-height: 1.22;
      font-weight: 700;
    }
    .blogs-hero p {
      margin-top: 8px;
    }
    .pagination {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin: 16px 0 0;
      align-items: center;
    }
    .pagination-link {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 32px;
      height: 32px;
      padding: 0 10px;
      border: 1px solid rgba(217, 119, 6, 0.30);
      background: #fff;
      color: #191919;
      font-size: 0.82rem;
    }
    .pagination-link.is-active {
      background: #fff1df;
      font-weight: 700;
    }
  </style>
</head>
<body>
  <div class="topbar">
    <div class="topbar-inner">
      <a class="brand" href="{{.HomeURL}}">
        <strong>{{.SiteTitle}}</strong>
        <span>{{.SiteSubtitle}}</span>
      </a>
      <nav class="tabs" aria-label="サイトナビゲーション">
        {{range .Tabs}}
        <a href="{{.TabURL}}"{{if .Active}} class="is-active"{{end}}>{{.TabLabel}}</a>
        {{end}}
      </nav>
    </div>
  </div>

  <main class="shell">
    {{.Body}}
  </main>

  <footer class="footer">
    <div class="shell">
      <span>{{.FootInformation}}</span>
      <span>{{.Copyright}}</span>
    </div>
  </footer>
</body>
</html>
{{end}}
